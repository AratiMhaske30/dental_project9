<%- include('header.ejs');  %>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Appointment</h1>
                <p class="text-muted mb-0">A clean starter page for new admin screens.</p>
              </div>
            </div>   
          </div>
          <section class="panel">
            <form action="Appointment_search" method="get">
              <label>From</label>
              <input type="date" name="from_date"/>
              <label>To</label>
              <input type="date" name="to_date"/>
              <label>Status</label>
              <select name="status">
                <option>Choose</option>
                <option>Pending</option>
                <option>Confirm</option>
                <option>Reject</option>
              </select>
              <button>Search</button>
            </form>
                <table class="table table-border mt-5">
                 <tr>
                <th>Sr.No</th>
                <th>Name</th>
                <th>Email</th>
                <th>Service Name</th>
                <th>Appointment Date</th>
                <th>Status</th>
                <th>Action</th>
                 </tr>
                <% for(var i=0; i<data.length; i++){ %>
                  <tr>
                <td><%= i + 1 %></td>
                <td><%= data[i].name %></td>
                <td><%= data[i].email %></td>
                <td><%= data[i].service_name %></td>
                <td><%= new Date(data[i].appointment_date).toISOString().split('T')[0] %></td>
                <td><%= data[i].status %></td>
                <td>
              <a href="/admin/ap_conf/<%= data[i].aid;  %>"><button class="btn">Confirm</button></a>
              <a href="/admin/ap_rejct/<%= data[i].aid;  %>/<%= data[i].bphoto;  %>"><button class="btn">Reject</button></a>
             </td>
          </tr>
        <% } %>
        </table>
          </section>
        </div>
      </main>
      <%- include('footer.ejs'); %>

    